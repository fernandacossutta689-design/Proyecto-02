<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EL MIRADOR - Restaurante Gourmet</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .hero-img { height: 500px; object-fit: cover; }
        footer { background-color: #212529; color: white; padding: 40px 0; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">EL MIRADOR</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#inicio">Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="#menu">Menú</a></li>
                    <li class="nav-item"><a class="nav-link" href="#reserva">Reservas</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <header id="inicio" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=1200&q=80" class="d-block w-100 hero-img" alt="Plato Gourmet">
                <div class="carousel-caption d-none d-md-block">
                    <h1>Experiencia Culinaria Única</h1>
                    <p>Sabores que despiertan tus sentidos.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?auto=format&fit=crop&w=1200&q=80" class="d-block w-100 hero-img" alt="Cena">
                <div class="carousel-caption d-none d-md-block">
                    <h1>Ingredientes Frescos</h1>
                    <p>Directo del campo a tu mesa.</p>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#inicio" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#inicio" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </header>

    <main class="container my-5" id="menu">
        <h2 class="text-center mb-4">Nuestro Menú Especial</h2>
        
        <div class="alert alert-info alert-dismissible fade show text-center" role="alert">
            <strong>¡Promoción del día!</strong> 2x1 en postres artesanales todos los jueves.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?auto=format&fit=crop&w=500&q=80" class="card-img-top" alt="Ensalada">
                    <div class="card-body">
                        <h5 class="card-title">Ensalada Zen</h5>
                        <p class="card-text">Mix de verdes, quinoa, aguacate y aderezo de cítricos.</p>
                        <button class="btn btn-outline-dark w-100">Ver Detalles</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <img src="https://images.unsplash.com/photo-1565299624946-b28f40a0ae38?auto=format&fit=crop&w=500&q=80" class="card-img-top" alt="Pizza">
                    <div class="card-body">
                        <h5 class="card-title">Pizza Napolitana</h5>
                        <p class="card-text">Masa madre, mozzarella de búfala y albahaca fresca.</p>
                        <button class="btn btn-outline-dark w-100">Ver Detalles</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 shadow-sm">
                    <img src="https://images.unsplash.com/photo-1544025162-d76694265947?auto=format&fit=crop&w=500&q=80" class="card-img-top" alt="Corte Carne">
                    <div class="card-body">
                        <h5 class="card-title">Corte Premium</h5>
                        <p class="card-text">Ojo de bife a las brasas con papas rústicas.</p>
                        <button class="btn btn-outline-dark w-100">Ver Detalles</button>
                    </div>
                </div>
            </div>
        </div>

        <hr class="my-5">

        <div class="row">
            <div class="col-lg-6">
                <h3>Horarios de Atención</h3>
                <ul class="list-group">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Lunes a Viernes
                        <span class="badge bg-primary rounded-pill">12:00 - 23:00</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Sábados
                        <span class="badge bg-primary rounded-pill">12:00 - 01:00</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Domingos
                        <span class="badge bg-secondary rounded-pill">Cerrado</span>
                    </li>
                </ul>
            </div>

            <div class="col-lg-6" id="reserva">
                <h3>Reserva tu Mesa</h3>
                <form class="p-4 border rounded shadow-sm">
                    <div class="mb-3">
                        <label class="form-label">Nombre completo</label>
                        <input type="text" class="form-control" placeholder="Juan Pérez" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha</label>
                        <input type="date" class="form-control" required>
                    </div>
                    <button type="button" class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#reservaModal">
                        Confirmar Reserva
                    </button>
                </form>
            </div>
        </div>
    </main>

    <div class="modal fade" id="reservaModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog text-center">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">¡Casi listo!</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>¿Estás seguro de que quieres realizar la reserva para esta fecha?</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success">Sí, Reservar</button>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <div class="container text-center">
            <div class="row">
                <div class="col-md-4">
                    <h5>EL MIRADOR</h5>
                    <p>La mejor cocina de la ciudad.</p>
                </div>
                <div class="col-md-4">
                    <h5>Contacto</h5>
                    <p>Calle Ficticia 123<br>Tel: +123 456 789</p>
                </div>
                <div class="col-md-4">
                    <h5>Síguenos</h5>
                    <p>Instagram | Facebook | Twitter</p>
                </div>
            </div>
            <hr class="bg-light">
            <p class="mb-0">&copy; 2026 Restaurante Sabores Pro - Todos los derechos reservados.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
